# =============================================================================
# PlanSync Environment Configuration
# Copy to .env and edit as needed: cp .env.example .env
# =============================================================================

# ─── Identity & Connection (used by bin/plansync launcher) ───────────────────
# PLANSYNC_USER=              # Your identity in PlanSync (default: system $USER)
# PLANSYNC_API_URL=http://localhost:3001   # API server address (skip for localhost)
# PLANSYNC_SECRET: API auth secret — must match across all team members and services
PLANSYNC_SECRET=dev-secret

# ─── Database ────────────────────────────────────────────────────────────────
# On shared machines (multiple users on same host), each user MUST use a unique
# PG_PORT to avoid connecting to another user's PostgreSQL instance.
# Suggestion: use 15000 + (your numeric UID % 1000), e.g. `expr 15000 + $(id -u) % 1000`
PG_PORT=15432
DATABASE_URL=postgresql://${USER}@localhost:${PG_PORT}/plansync_dev

# ─── API Server ──────────────────────────────────────────────────────────────
# PORT=3000                   # API port (Next.js default 3000)
# AUTH_DISABLED=false         # true = skip auth (local dev only)
# LOG_LEVEL=info              # debug | info | warn | error
# NODE_ENV=development

# ─── AI Features (semantic diff, optional — pick one) ────────────────────────
# Option A: AMD internal LLM API
# LLM_API_KEY=                # Subscription Key
# LLM_API_BASE=https://llm-api.amd.com
# LLM_MODEL_NAME=Claude-Sonnet-4.5
#
# Option B: Anthropic official API
# ANTHROPIC_API_KEY=sk-ant-xxx

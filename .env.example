# =============================================================================
# PlanSync Environment Configuration
# =============================================================================
# Copy to .env and edit as needed: cp .env.example .env
#
# `./bin/ps-admin start` auto-copies this file to .env on first run.
#
# What you actually need to edit:
#   1. AI features won't work without an API key — set LLM_API_KEY (AMD)
#      or ANTHROPIC_API_KEY. Without one of these, semantic plan diff,
#      AI completion verification, and conflict prediction all silently
#      no-op. Half the value of PlanSync. Don't skip this.
#   2. Shared host / cluster: you MUST change PG_PORT to avoid colliding
#      with other users' Postgres on the same machine.
#
# Local single-user laptop without AI: defaults work, edit nothing.
# =============================================================================


# ─── DATABASE — PG_PORT MUST be unique on shared hosts ───────────────────────
# Multiple users on the same machine WILL collide on the default port and
# connect to each other's PostgreSQL. Pick a per-user port:
#   PG_PORT=$(expr 15000 + $(id -u) % 1000)
PG_PORT=15432
DATABASE_URL=postgresql://${USER}@localhost:${PG_PORT}/plansync_dev


# ─── AI FEATURES — strongly recommended (set one) ────────────────────────────
# Without an API key, these silently stop working:
#   - semantic plan diff (plan_diff returns rule-based diff only)
#   - AI completion verification (deliverablesMet check in execution_complete)
#   - AI task-conflict prediction (plansync_check_task_conflicts returns null)
#   - AI-enriched drift impact analysis
# Pick exactly one provider.
#
# Option A — AMD internal LLM (Anthropic-compatible)
# LLM_API_KEY=
# LLM_API_BASE=https://llm-api.amd.com/Anthropic
# LLM_MODEL_NAME=Claude-Sonnet-4.5
#
# Option B — Anthropic official API
# ANTHROPIC_API_KEY=sk-ant-xxx


# ─── EMAIL NOTIFICATIONS ─────────────────────────────────────────────────────
# Uses /usr/sbin/sendmail directly — no SMTP setup needed on Linux.
# EMAIL_DOMAIN is appended to your $USER (e.g. nanyang2 → nanyang2@amd.com).
EMAIL_DOMAIN=amd.com
# EMAIL_FROM=plansync@amd.com


# ─── IDENTITY (rarely needed — only override if defaults don't suit you) ─────
# bin/plansync handles all of these for you on first run:
#   - prompts for username (default: $USER) and password (= your API key)
#   - saves them to ~/.config/plansync/env
# Set them here only if you need a different value or are running on a host
# that bin/plansync isn't managing.
# PLANSYNC_USER=
# PLANSYNC_API_URL=http://localhost:3001
# PLANSYNC_API_KEY=


# ─── API SERVER (advanced — defaults are fine) ───────────────────────────────
# PORT=3001                   # API server port
# AUTH_DISABLED=false         # true = skip auth (local dev only, never in prod)
# LOG_LEVEL=info              # debug | info | warn | error
# NODE_ENV=development

{
  "name": "plansync",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "dev": "bash scripts/dev.sh",
    "build": "bash scripts/build.sh",
    "test": "bash scripts/test.sh",
    "lint": "bash scripts/lint.sh",
    "format": "bash scripts/format.sh",
    "db:start": "bash scripts/pg-start.sh",
    "db:stop": "bash scripts/pg-stop.sh",
    "db:reset": "bash scripts/db-reset.sh",
    "db:psql": "bash scripts/db-psql.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "eslint": "~9.17.0",
    "@eslint/js": "~9.17.0",
    "@typescript-eslint/eslint-plugin": "~8.18.0",
    "@typescript-eslint/parser": "~8.18.0",
    "prettier": "~3.4.2",
    "husky": "~9.1.7",
    "@commitlint/cli": "~19.6.1",
    "@commitlint/config-conventional": "~19.6.0",
    "lint-staged": "~15.4.3",
    "typescript": "~5.7.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}

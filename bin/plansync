#!/bin/bash
# PlanSync — PlanSync Terminal with AI and /code coding mode
# Default: launches PlanSync Terminal REPL (AI chat + /code for Genie/Claude)
# --host genie|claude: launch AI coding tool directly with MCP (advanced/CI use)
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
GENIE_BIN="${GENIE_BIN:-/proj/verif_release_ro/genie/current/bin/genie}"
CLAUDE_BIN="${CLAUDE_BIN:-$(command -v claude 2>/dev/null || echo "$HOME/.npm-global/bin/claude")}"

# shellcheck source=scripts/local-node-runtime.sh
. "$PROJECT_DIR/scripts/local-node-runtime.sh"

die() { echo "❌ $*" >&2; exit 1; }

require_arg() {
  [[ -n "${2:-}" && "${2:-}" != --* ]] || die "Option $1 requires a value. See --help."
}

# ─── Parse arguments ───
HOST="terminal"
PLANSYNC_PROJ=""
PLANSYNC_USER_ARG=""
WORK_DIR="$(pwd)"
PASSTHROUGH_ARGS=()
EXEC_TASK_ID=""
EXEC_HOST="genie"

while [[ $# -gt 0 ]]; do
  case $1 in
    --run)        HOST="run"; shift ;;
    --exec)       require_arg "$1" "${2:-}"; EXEC_TASK_ID="$2"; HOST="exec"; shift 2 ;;
    --exec-host)  require_arg "$1" "${2:-}"; EXEC_HOST="$2"; shift 2 ;;
    --host)       require_arg "$1" "${2:-}"; HOST="$2"; shift 2 ;;
    --project)    require_arg "$1" "${2:-}"; PLANSYNC_PROJ="$2"; shift 2 ;;
    --user)       require_arg "$1" "${2:-}"; PLANSYNC_USER_ARG="$2"; shift 2 ;;
    --dir)        require_arg "$1" "${2:-}"; WORK_DIR="$2"; shift 2 ;;
    install)
      # Deprecated: MCP is now pre-configured via .claude/settings.json (committed to git).
      # No manual install step needed — just clone and open Claude Code.
      # Run ./bin/plansync once to set up your credentials (~/.config/plansync/env).
      echo "ℹ️  install is no longer needed." >&2
      echo "   PlanSync MCP is pre-configured via .claude/settings.json (committed to git)." >&2
      echo "   Just run ./bin/plansync once to set up your credentials." >&2
      exit 0
      ;;
    --help|-h)
      cat <<'USAGE'
Usage: plansync [COMMAND] [OPTIONS]

  PlanSync Terminal — AI assistant with /code coding mode.

Commands:
  install                      Install PlanSync into ~/.claude/settings.json for persistent
                               MCP access across all Claude/Genie sessions. Run once after
                               cloning. Normal launch does NOT modify ~/.claude/.

Options:
  --run                        Run as an autonomous agent: process all pending work
                               (reviews, tasks, drift alerts) for PLANSYNC_USER, then exit.
                               Idempotent — safe to call from cron; exits 0 if no work.
  --exec TASK_ID               Launch /code with task context pre-loaded for implementation.
                               Fetches the task pack and opens a genie/claude session
                               for full IDE execution. Use --exec-host to pick claude.
                               Requires --project or PLANSYNC_PROJECT.
  --exec-host genie|claude     AI tool to use for --exec (default: genie)
  --host terminal|genie|claude|cursor
                               Interface to use (default: terminal)
                               terminal: PlanSync Terminal REPL (recommended)
                               genie/claude: launch AI tool directly with MCP (CI/advanced)
                               cursor: configure Cursor MCP integration
  --project PROJECT_ID         PlanSync project ID (optional)
  --user USER_NAME             Identity for this session (overrides PLANSYNC_USER)
  --dir PATH                   Working directory (default: current dir)
  --help                       Show this help

Environment:
  PLANSYNC_API_URL   API server URL (default: http://localhost:3001)
  PLANSYNC_API_KEY   Your login password (prompted automatically on first run)
  PLANSYNC_USER      Your username (default: $USER)
  PG_BIN             PostgreSQL binary directory (default: /tool/pandora64/bin)
  GENIE_BIN          Path to Genie binary (default: /proj/verif_release_ro/...)
  CORS_ORIGINS       Additional CORS origins, comma-separated

AI (pick one):
  LLM_API_KEY        AMD internal LLM API subscription key
  LLM_API_BASE       AMD LLM API base URL (default: https://llm-api.amd.com)
  LLM_MODEL_NAME     Model name (default: Claude-Sonnet-4.5)
  ANTHROPIC_API_KEY  Anthropic API key (external users)

Examples:
  plansync                          # Launch PlanSync Terminal (default; first run prompts for credentials)
  plansync --project clxyz123       # Specify project, then launch terminal
  plansync --user alice             # Set identity for this session
  plansync --host genie             # Launch Genie directly with PlanSync MCP (no terminal)
  plansync --host claude            # Launch Claude Code with PlanSync MCP
  plansync --host cursor            # Configure Cursor (writes .cursor/mcp.json)
  plansync --run --project <id>     # Run as agent: process all pending work, then exit
  plansync --exec abc123 --project xyz456   # Open task in /code for implementation
  plansync --exec abc123 --exec-host claude # Same but use Claude instead of Genie
USAGE
      exit 0
      ;;
    --)           shift; PASSTHROUGH_ARGS=("$@"); break ;;
    *)            PASSTHROUGH_ARGS+=("$1"); shift ;;
  esac
done

# ─── Prepare project-local runtime for end users ───
ensure_user_runtime_ready

# ─── Load .env (existing env vars take precedence) ───
_load_env() {
  [ -f "$1" ] || return 0
  while IFS= read -r _line; do
    [[ "$_line" =~ ^[[:space:]]*($|#) ]] && continue
    local _key="${_line%%=*}"
    _key="${_key// /}"
    [ -n "${!_key+set}" ] || export "$_line"
  done < "$1"
}

# ─── First-run credential setup ───
# Prompts for username+password on first run, saves to ~/.config/plansync/env.
# Subsequent runs verify existing credentials against the server before continuing.
_ensure_credentials() {
  if [ -n "$PLANSYNC_API_KEY" ]; then
    # Verify existing credentials against server (read-only, does not invalidate browser sessions)
    _ec_ok=$(
      _EC_URL="$PLANSYNC_API_URL" _EC_U="${PLANSYNC_USER:-$USER}" _EC_P="$PLANSYNC_API_KEY" \
      "$LOCAL_NODE_BIN" -e "
        const h=require('http'),u=new URL('/api/auth/verify',process.env._EC_URL);
        const b=JSON.stringify({userName:process.env._EC_U,password:process.env._EC_P});
        h.request({hostname:u.hostname,port:u.port||80,path:u.pathname,
          method:'POST',headers:{'Content-Type':'application/json'}},r=>{
          let d='';r.on('data',c=>d+=c);
          r.on('end',()=>{try{process.stdout.write(JSON.parse(d).success?'ok':'fail');}catch{process.stdout.write('fail');}});
        }).end(b);
      " 2>/dev/null
    )
    if [ "$_ec_ok" = "ok" ]; then
      return 0   # credentials valid, fast path
    fi
    # Stale credentials (e.g. DB was reset) — fall through to re-prompt
    printf '\n⚠️  Stored credentials no longer valid. Please re-enter.\n' >&2
    unset PLANSYNC_API_KEY
  fi
  if [[ ! -t 0 ]]; then
    die "PLANSYNC_API_KEY not set. Run ./bin/plansync once interactively to configure credentials."
  fi
  _ec_user="${PLANSYNC_USER:-$USER}"
  printf '\nPlanSync first-time setup\n' >&2
  printf 'Username is %s\n' "$_ec_user" >&2
  # Try with confirm password first (new account flow)
  while true; do
    printf 'Set your password: ' >&2
    read -rs _ec_pass
    printf '\n' >&2
    printf 'Confirm password: ' >&2
    read -rs _ec_pass2
    printf '\n' >&2
    if [ "$_ec_pass" = "$_ec_pass2" ]; then
      break
    fi
    printf 'Passwords do not match. Please try again.\n' >&2
  done
  # Verify credentials via server. Use node to safely handle special chars (e.g. !).
  _ec_ok=$(
    _EC_URL="$PLANSYNC_API_URL" _EC_U="$_ec_user" _EC_P="$_ec_pass" \
    "$LOCAL_NODE_BIN" -e "
      const h=require('http'),u=new URL('/api/auth/login',process.env._EC_URL);
      const b=JSON.stringify({userName:process.env._EC_U,password:process.env._EC_P});
      const req=h.request({hostname:u.hostname,port:u.port||80,path:u.pathname,
        method:'POST',headers:{'Content-Type':'application/json','Content-Length':Buffer.byteLength(b)}},r=>{
        let d='';r.on('data',c=>d+=c);
        r.on('end',()=>{
          try{
            const j=JSON.parse(d);
            if(j.success){process.stdout.write('ok');}
            else{process.stdout.write('ERR:'+(j.error||'unknown error'));}
          }catch{process.stdout.write('ERR:invalid response');}
        });
      });
      req.on('error',e=>process.stdout.write('ERR:'+e.message));
      req.write(b);req.end();
    " 2>/dev/null
  )
  if [ "$_ec_ok" = "ok" ]; then
    mkdir -p "$HOME/.config/plansync"
    # Write via node — avoids shell ! expansion issues with special chars in passwords
    _EC_F="$HOME/.config/plansync/env" _EC_P="$_ec_pass" _EC_U="$_ec_user" \
    "$LOCAL_NODE_BIN" -e "
      require('fs').writeFileSync(process.env._EC_F,
        'PLANSYNC_API_KEY='+process.env._EC_P+'\nPLANSYNC_USER='+process.env._EC_U+'\n',
        {mode:0o600});
    "
    export PLANSYNC_API_KEY="$_ec_pass"
    export PLANSYNC_USER="$_ec_user"
    printf 'Credentials saved to %s\n' "$HOME/.config/plansync/env" >&2
    printf '\nWelcome to PlanSync, %s! Your account is ready.\n\n' "$_ec_user" >&2
  else
    _ec_err="${_ec_ok#ERR:}"
    if [[ "$_ec_err" == *"Invalid username or password"* ]]; then
      printf 'Account already exists. Please enter your existing password: ' >&2
      read -rs _ec_pass
      printf '\n' >&2
      _ec_ok2=$(
        _EC_URL="$PLANSYNC_API_URL" _EC_U="$_ec_user" _EC_P="$_ec_pass" \
        "$LOCAL_NODE_BIN" -e "
          const h=require('http'),u=new URL('/api/auth/verify',process.env._EC_URL);
          const b=JSON.stringify({userName:process.env._EC_U,password:process.env._EC_P});
          const req=h.request({hostname:u.hostname,port:u.port||80,path:u.pathname,
            method:'POST',headers:{'Content-Type':'application/json','Content-Length':Buffer.byteLength(b)}},r=>{
            let d='';r.on('data',c=>d+=c);
            r.on('end',()=>{
              try{
                const j=JSON.parse(d);
                if(j.success){process.stdout.write('ok');}
                else{process.stdout.write('ERR:'+(j.error||'unknown error'));}
              }catch{process.stdout.write('ERR:invalid response');}
            });
          });
          req.on('error',e=>process.stdout.write('ERR:'+e.message));
          req.write(b);req.end();
        " 2>/dev/null
      )
      if [ "$_ec_ok2" = "ok" ]; then
        mkdir -p "$HOME/.config/plansync"
        _EC_F="$HOME/.config/plansync/env" _EC_P="$_ec_pass" _EC_U="$_ec_user" \
        "$LOCAL_NODE_BIN" -e "
          require('fs').writeFileSync(process.env._EC_F,
            'PLANSYNC_API_KEY='+process.env._EC_P+'\nPLANSYNC_USER='+process.env._EC_U+'\n',
            {mode:0o600});
        "
        export PLANSYNC_API_KEY="$_ec_pass"
        export PLANSYNC_USER="$_ec_user"
        printf 'Credentials saved to %s\n' "$HOME/.config/plansync/env" >&2
        printf '\nWelcome to PlanSync, %s!\n\n' "$_ec_user" >&2
      else
        printf 'Login failed: %s\n' "${_ec_ok2#ERR:}" >&2
        exit 1
      fi
    else
      printf 'Login failed: %s\n' "${_ec_err:-no response from server}" >&2
      exit 1
    fi
  fi
}

_load_env "$PROJECT_DIR/.env"
_load_env "$HOME/.config/plansync/env"

# ─── Config (env > .env > defaults) ───
export PLANSYNC_API_URL="${PLANSYNC_API_URL:-$(plansync_api_url 3001)}"
export PLANSYNC_API_KEY="${PLANSYNC_API_KEY:-}"
export PLANSYNC_USER="${PLANSYNC_USER_ARG:-${PLANSYNC_USER:-${USER}}}"
export PLANSYNC_PROJECT="${PLANSYNC_PROJ}"

MCP_SERVER="$PROJECT_DIR/packages/mcp-server/dist/index.js"

# ─── Validate working directory ───
if [ ! -d "$WORK_DIR" ]; then
  echo "📁 Creating working directory: $WORK_DIR" >&2
  mkdir -p "$WORK_DIR"
fi
WORK_DIR_ABS="$(cd "$WORK_DIR" && pwd)"

# ─── Check API is reachable ───
if curl -s --connect-timeout 2 "$PLANSYNC_API_URL/api/health" >/dev/null 2>&1; then
  echo "✅ PlanSync API reachable at $PLANSYNC_API_URL" >&2
else
  echo "⚠️  PlanSync API not reachable at $PLANSYNC_API_URL" >&2
  echo "   Start it first: cd $PROJECT_DIR && ./bin/ps-admin start" >&2
  echo "   Or set PLANSYNC_API_URL to the correct URL." >&2
  echo "" >&2
  if [[ -t 0 ]]; then
    read -p "   Continue anyway? [y/n] " -n 1 -r
    echo >&2
    [[ $REPLY =~ ^[Yy]$ ]] || exit 1
  else
    die "API not reachable. Start the API server first."
  fi
fi

_ensure_credentials

# ─── Inject CLAUDE.md / AGENTS.md into working directory ───
INSTRUCTIONS_SRC="$PROJECT_DIR/claude-md/plansync-instructions.md"
inject_instructions() {
  local target_dir="$1"

  if [ -f "$INSTRUCTIONS_SRC" ]; then
    # Claude Code reads CLAUDE.md
    if [ -f "$target_dir/CLAUDE.md" ]; then
      if ! grep -q "PlanSync" "$target_dir/CLAUDE.md" 2>/dev/null; then
        printf '\n---\n\n' >> "$target_dir/CLAUDE.md"
        cat "$INSTRUCTIONS_SRC" >> "$target_dir/CLAUDE.md"
        echo "📝 PlanSync instructions appended to CLAUDE.md" >&2
      fi
    else
      cp "$INSTRUCTIONS_SRC" "$target_dir/CLAUDE.md"
      echo "📝 CLAUDE.md created with PlanSync instructions" >&2
    fi

    # Codex reads AGENTS.md — use engine-agnostic instructions (not CLAUDE.md terminal instructions)
    local CODEX_SRC="$PROJECT_DIR/claude-md/plansync-instructions.md"
    if [ -f "$CODEX_SRC" ]; then
      if [ -f "$target_dir/AGENTS.md" ]; then
        if ! grep -q "PlanSync" "$target_dir/AGENTS.md" 2>/dev/null; then
          printf '\n---\n\n' >> "$target_dir/AGENTS.md"
          cat "$CODEX_SRC" >> "$target_dir/AGENTS.md"
          echo "📝 PlanSync instructions appended to AGENTS.md" >&2
        fi
      else
        cp "$CODEX_SRC" "$target_dir/AGENTS.md"
        echo "📝 AGENTS.md created with PlanSync instructions" >&2
      fi
    fi
  fi
}

# ─── Inject MCP config (uses node with env vars to avoid shell injection) ───
export _PS_MCP_SERVER="$MCP_SERVER"
export _PS_NODE_BIN="$LOCAL_NODE_BIN"
export _PS_API_URL="$PLANSYNC_API_URL"
export _PS_API_KEY="$PLANSYNC_API_KEY"
export _PS_USER="$PLANSYNC_USER"
export _PS_PROJECT="$PLANSYNC_PROJ"
export _PS_WORK_DIR="$WORK_DIR_ABS"

inject_claude_settings() {
  mkdir -p "$HOME/.claude"

  "$LOCAL_NODE_BIN" -e '
    const fs = require("fs");
    const mcpEntry = {
      command: process.env._PS_NODE_BIN,
      args: [process.env._PS_MCP_SERVER],
      env: {
        PLANSYNC_API_URL: process.env._PS_API_URL,
        PLANSYNC_API_KEY: process.env._PS_API_KEY,
        PLANSYNC_USER: process.env._PS_USER,
        PLANSYNC_PROJECT: process.env._PS_PROJECT || "",
        LOG_LEVEL: "warn",
      },
    };

    const sf = process.env.HOME + "/.claude/settings.json";
    let settings = {};
    try { settings = JSON.parse(fs.readFileSync(sf, "utf8")); } catch {}

    // Top-level mcpServers: Claude Code 2.x reads from here for interactive sessions
    if (!settings.mcpServers) settings.mcpServers = {};
    settings.mcpServers.plansync = mcpEntry;

    // Auto-allow all plansync MCP tools (no permission prompts)
    if (!settings.permissions) settings.permissions = {};
    if (!settings.permissions.allow) settings.permissions.allow = [];
    if (!settings.permissions.allow.includes("mcp__plansync__*")) {
      settings.permissions.allow.push("mcp__plansync__*");
    }

    // Per-project trust dialog acceptance
    if (!settings.projects) settings.projects = {};
    const key = process.env._PS_WORK_DIR;
    if (!settings.projects[key]) settings.projects[key] = {};
    settings.projects[key].hasTrustDialogAccepted = true;

    fs.writeFileSync(sf, JSON.stringify(settings, null, 2));
  '
  echo "🔧 MCP config injected into Claude settings for $WORK_DIR_ABS" >&2
}

inject_cursor_settings() {
  local target_dir="$1"
  local cursor_mcp="$target_dir/.cursor/mcp.json"
  mkdir -p "$target_dir/.cursor"

  _PS_CURSOR_MCP="$cursor_mcp" "$LOCAL_NODE_BIN" -e '
    const fs = require("fs");
    const fp = process.env._PS_CURSOR_MCP;
    let conf = {};
    try { conf = JSON.parse(fs.readFileSync(fp, "utf8")); } catch {}
    if (!conf.mcpServers) conf.mcpServers = {};
    conf.mcpServers.plansync = {
      command: process.env._PS_NODE_BIN,
      args: [process.env._PS_MCP_SERVER],
      env: {
        PLANSYNC_API_URL: process.env._PS_API_URL,
        PLANSYNC_API_KEY: process.env._PS_API_KEY,
        PLANSYNC_USER: process.env._PS_USER,
        PLANSYNC_PROJECT: process.env._PS_PROJECT || "",
        LOG_LEVEL: "warn",
      },
    };
    fs.writeFileSync(fp, JSON.stringify(conf, null, 2));
  '
}

# ─── Engine detection (codex vs claude-code) ───
_detect_engine() {
  if [ "${GENIE_AGENT_ENGINE:-}" = "codex" ]; then
    echo "codex"
  elif [ "${GENIE_AGENT_ENGINE:-}" = "claude-code" ]; then
    echo "claude-code"
  else
    local help_output
    help_output=$("$GENIE_BIN" help 2>&1 || true)
    if echo "$help_output" | grep -q "Codex CLI"; then
      echo "codex"
    else
      echo "claude-code"
    fi
  fi
}

_setup_codex_mcp() {
  "$GENIE_BIN" -- mcp remove plansync 2>/dev/null || true
  "$GENIE_BIN" -- mcp add plansync \
    --env "PLANSYNC_API_URL=$PLANSYNC_API_URL" \
    --env "PLANSYNC_API_KEY=$PLANSYNC_API_KEY" \
    --env "PLANSYNC_USER=$PLANSYNC_USER" \
    --env "PLANSYNC_PROJECT=${PLANSYNC_PROJECT:-}" \
    --env "LOG_LEVEL=warn" \
    -- "$LOCAL_NODE_BIN" "$MCP_SERVER" 2>/dev/null
}

_cleanup_codex_mcp() {
  "$GENIE_BIN" -- mcp remove plansync 2>/dev/null || true
}

# ─── Host-specific launch ───
case "$HOST" in

  terminal)
    echo "" >&2
    echo "🚀 Starting PlanSync Terminal..." >&2
    echo "   User: $PLANSYNC_USER | API: $PLANSYNC_API_URL" >&2
    [[ -n "$PLANSYNC_PROJECT" ]] && echo "   Project: $PLANSYNC_PROJECT" >&2 || true
    echo "" >&2

    CLI_DIST="$PROJECT_DIR/packages/cli/dist/index.js"
    if [ ! -f "$CLI_DIST" ]; then
      echo "❌ PlanSync Terminal not built. Run:" >&2
      echo "   cd $PROJECT_DIR/packages/cli && node ../../node_modules/.bin/esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/index.js --format=cjs" >&2
      exit 1
    fi

    PLANSYNC_MCP_SERVER="$MCP_SERVER" \
    PLANSYNC_NODE_BIN="$LOCAL_NODE_BIN" \
    GENIE_BIN="$GENIE_BIN" \
    exec "$LOCAL_NODE_BIN" "$CLI_DIST"
    ;;

  genie|claude)
    inject_instructions "$WORK_DIR_ABS"

    echo "" >&2
    echo "🚀 Launching ${HOST} with PlanSync MCP..." >&2
    echo "   User: $PLANSYNC_USER | API: $PLANSYNC_API_URL" >&2
    echo "   Working dir: $WORK_DIR_ABS" >&2
    echo "" >&2

    # Build --mcp-config JSON inline (same mechanism that works for genie -p in E2E tests)
    MCP_CONFIG_JSON="$("$LOCAL_NODE_BIN" -e '
      const cfg = {
        mcpServers: {
          plansync: {
            command: process.env._PS_NODE_BIN,
            args: [process.env._PS_MCP_SERVER],
            env: {
              PLANSYNC_API_URL: process.env._PS_API_URL,
              PLANSYNC_API_KEY: process.env._PS_API_KEY,
              PLANSYNC_USER: process.env._PS_USER,
              PLANSYNC_PROJECT: process.env._PS_PROJECT || "",
              LOG_LEVEL: "warn",
            },
          },
        },
      };
      process.stdout.write(JSON.stringify(cfg));
    ')"

    cd "$WORK_DIR_ABS"
    if [ "$HOST" = "genie" ]; then
      ENGINE=$(_detect_engine)
      if [ "$ENGINE" = "codex" ]; then
        _setup_codex_mcp
        exec "$GENIE_BIN" -- --full-auto "${PASSTHROUGH_ARGS[@]}"
      else
        exec "$GENIE_BIN" --mcp-config "$MCP_CONFIG_JSON" "${PASSTHROUGH_ARGS[@]}"
      fi
    else
      exec "$CLAUDE_BIN" --mcp-config "$MCP_CONFIG_JSON" "${PASSTHROUGH_ARGS[@]}"
    fi
    ;;

  cursor)
    inject_cursor_settings "$WORK_DIR_ABS"
    inject_instructions "$WORK_DIR_ABS"

    echo "✅ Cursor MCP config written to $WORK_DIR_ABS/.cursor/mcp.json" >&2
    echo "   Restart Cursor or reload the window to activate PlanSync." >&2
    echo "" >&2
    echo "   PlanSync is now available in Cursor's AI chat." >&2
    echo "   Try asking: 'show project status' or 'create a plan for auth system'" >&2
    ;;

  run)
    [[ -n "$PLANSYNC_PROJECT" ]] || die "--run requires --project <id> or PLANSYNC_PROJECT env var"

    echo "" >&2
    echo "🤖 PlanSync agent run — user: $PLANSYNC_USER | project: $PLANSYNC_PROJECT" >&2
    echo "" >&2

    inject_instructions "$WORK_DIR_ABS"

    MCP_CONFIG_JSON="$("$LOCAL_NODE_BIN" -e '
      const cfg = {
        mcpServers: {
          plansync: {
            command: process.env._PS_NODE_BIN,
            args: [process.env._PS_MCP_SERVER],
            env: {
              PLANSYNC_API_URL: process.env._PS_API_URL,
              PLANSYNC_API_KEY: process.env._PS_API_KEY,
              PLANSYNC_USER: process.env._PS_USER,
              PLANSYNC_PROJECT: process.env._PS_PROJECT || "",
              LOG_LEVEL: "warn",
            },
          },
        },
      };
      process.stdout.write(JSON.stringify(cfg));
    ')"

    # Construct the agent prompt — explicit work queue + required tool sequence
    RUN_PROMPT="You are PlanSync agent ${PLANSYNC_USER}. Your job is to process all pending work assigned to you.

Step 1: Call plansync_my_work { projectId: \"${PLANSYNC_PROJECT}\" }

If hasWork=false: output \"${PLANSYNC_USER}: no pending work.\" and exit immediately.

If hasWork=true, process all work items in priority order:

[P0 Drift Alerts] For each:
  → plansync_task_pack { taskId } to inspect the drift
  → plansync_drift_resolve { driftId, action: rebind|no_impact|cancel }

[P1 Plan Reviews] For each, strictly in this order:
  1. plansync_plan_show { planId } — read the full plan content
  2. plansync_comment_create — write your review analysis (state what you support/oppose and why)
  3. plansync_review_approve or plansync_review_reject

[P2 Assigned Tasks] For each:
  → plansync_task_pack { taskId } — check for drift (resolve if present)
  → plansync_comment_create — describe your execution plan
  → plansync_execution_start → do the work → plansync_execution_complete

Rule: always call plansync_comment_create before approve/reject/complete — keeps work auditable.
Output a summary when all work is done, then exit."

    cd "$WORK_DIR_ABS"
    ENGINE=$(_detect_engine)
    if [ "$ENGINE" = "codex" ]; then
      _setup_codex_mcp
      exec "$GENIE_BIN" -- exec "$RUN_PROMPT" --dangerously-bypass-approvals-and-sandbox
    else
      exec "$GENIE_BIN" --mcp-config "$MCP_CONFIG_JSON" -p "$RUN_PROMPT"
    fi
    ;;

  exec)
    [[ -n "$PLANSYNC_PROJECT" ]] || die "--exec requires --project <id> or PLANSYNC_PROJECT env var"
    [[ -n "$EXEC_TASK_ID" ]] || die "--exec requires a task ID argument"

    EXEC_BIN="$GENIE_BIN"
    [[ "$EXEC_HOST" = "claude" ]] && EXEC_BIN="$CLAUDE_BIN"

    echo "" >&2
    echo "📋 Fetching task pack for $EXEC_TASK_ID..." >&2

    # Fetch task pack via API using env vars to avoid shell injection
    export _PS_EXEC_TASK_ID="$EXEC_TASK_ID"
    TASK_PACK_JSON="$("$LOCAL_NODE_BIN" -e '
      const h = require("http");
      const url = new URL(
        "/api/projects/" + process.env._PS_PROJECT +
        "/tasks/" + process.env._PS_EXEC_TASK_ID + "/pack",
        process.env._PS_API_URL
      );
      h.get({
        hostname: url.hostname,
        port: url.port || 80,
        path: url.pathname,
        headers: { "Authorization": "Bearer " + process.env._PS_API_KEY }
      }, (res) => {
        let d = "";
        res.on("data", c => d += c);
        res.on("end", () => {
          try {
            const j = JSON.parse(d);
            if (j.error) { process.stderr.write("API error: " + j.error + "\n"); process.exit(1); }
            process.stdout.write(JSON.stringify(j, null, 2));
          } catch { process.stderr.write("Invalid response\n"); process.exit(1); }
        });
      }).on("error", e => { process.stderr.write("ERROR: " + e.message + "\n"); process.exit(1); });
    ' 2>&1)" || die "Failed to fetch task pack. Check task ID and project."

    # Check for drift alerts in the response
    HAS_DRIFT="$("$LOCAL_NODE_BIN" -e '
      try {
        const d = JSON.parse(process.argv[1] || "{}");
        const alerts = (d.driftAlerts || []).filter(a => a.status === "open");
        process.stdout.write(alerts.length > 0 ? "yes" : "no");
      } catch { process.stdout.write("no"); }
    ' "$TASK_PACK_JSON" 2>/dev/null || echo "no")"

    if [ "$HAS_DRIFT" = "yes" ]; then
      echo "⚠️  Task $EXEC_TASK_ID has unresolved drift alerts." >&2
      echo "   Resolve them in PlanSync Terminal before executing." >&2
      exit 1
    fi

    # Build MCP config (same pattern as run/genie modes)
    MCP_CONFIG_JSON="$("$LOCAL_NODE_BIN" -e '
      const cfg = {
        mcpServers: {
          plansync: {
            command: process.env._PS_NODE_BIN,
            args: [process.env._PS_MCP_SERVER],
            env: {
              PLANSYNC_API_URL: process.env._PS_API_URL,
              PLANSYNC_API_KEY: process.env._PS_API_KEY,
              PLANSYNC_USER: process.env._PS_USER,
              PLANSYNC_PROJECT: process.env._PS_PROJECT || "",
              LOG_LEVEL: "warn",
            },
          },
        },
      };
      process.stdout.write(JSON.stringify(cfg));
    ')"

    inject_instructions "$WORK_DIR_ABS"

    # Construct the execution prompt
    EXEC_PROMPT="You are PlanSync agent ${PLANSYNC_USER} about to execute a task.

IMPORTANT: Do NOT write any code yet. First, analyze the task and present your implementation plan for user approval.

Task Pack (from PlanSync):
${TASK_PACK_JSON}

Execution protocol:
1. Call plansync_task_pack with taskId=\"${EXEC_TASK_ID}\" and projectId=\"${PLANSYNC_PROJECT}\" to confirm current state
2. If drift alerts present: stop, show them to the user, and wait
3. Present your approach: what files you will change, what steps you will take, how you will meet each deliverable listed in the task pack
4. Wait for user approval before writing any code
5. Once approved: call plansync_execution_start (executorType=\"agent\", executorName=\"${PLANSYNC_USER}\")
6. Implement the solution using your available tools
7. Call plansync_execution_complete with a specific deliverablesMet list (each item must name a concrete output, not vague phrases like \"completed the task\")
8. Call plansync_task_update status=\"done\"

Project: ${PLANSYNC_PROJECT}  |  Task: ${EXEC_TASK_ID}"

    echo "🚀 Launching ${EXEC_HOST} for task execution..." >&2
    echo "   Task: $EXEC_TASK_ID | User: $PLANSYNC_USER | Project: $PLANSYNC_PROJECT" >&2
    echo "" >&2

    cd "$WORK_DIR_ABS"
    if [ "$EXEC_HOST" = "claude" ]; then
      exec "$EXEC_BIN" --mcp-config "$MCP_CONFIG_JSON" -p "$EXEC_PROMPT"
    else
      ENGINE=$(_detect_engine)
      if [ "$ENGINE" = "codex" ]; then
        _setup_codex_mcp
        exec "$EXEC_BIN" -- --full-auto "$EXEC_PROMPT"
      else
        exec "$EXEC_BIN" --mcp-config "$MCP_CONFIG_JSON" -p "$EXEC_PROMPT"
      fi
    fi
    ;;

  *)
    die "Unknown host: $HOST (supported: terminal, genie, claude, cursor, --run, --exec)"
    ;;
esac

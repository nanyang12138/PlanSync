#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

# shellcheck source=scripts/local-node-runtime.sh
. "$PROJECT_DIR/scripts/local-node-runtime.sh"

usage() {
  cat <<'EOF'
Usage: ps-admin [start|setup|reset|gen-key|help]

Commands:
  start     Prepare server dependencies if needed, then start PlanSync API
  setup     Run the full explicit owner bootstrap flow
  reset     Reset the local PostgreSQL data and rerun setup
  gen-key   Log in and print an API key (PLANSYNC_API_KEY) for MCP/CLI use
  help      Show this help
EOF
}

print_header() {
  echo "PlanSync Admin"
  echo "--------------"
}

command="${1:-start}"
shift || true

case "$command" in
  start)
    api_url="${PLANSYNC_API_URL:-$(plansync_api_url "${PORT:-3001}")}"
    print_header
    echo "Preparing owner environment and starting the API..."
    if is_plansync_api_reachable "$api_url"; then
      echo "==> PlanSync API is already running at $api_url"
      mkdir -p "$PROJECT_DIR/data" && hostname > "$PROJECT_DIR/data/server_host"
      exit 0
    fi
    if port_in_use "${PORT:-3001}"; then
      echo "==> Port ${PORT:-3001} is already in use by another process"
      echo "    Stop the process using that port, or rerun with PORT=<new-port> PLANSYNC_API_URL=http://localhost:<new-port>"
      exit 1
    fi
    ensure_owner_runtime_ready
    if [ "${OWNER_RUNTIME_FRESH_DB:-0}" -ne 0 ]; then
      seed_demo_if_requested
    fi
    mkdir -p "$PROJECT_DIR/data" && hostname > "$PROJECT_DIR/data/server_host"
    echo "==> Starting PlanSync API"
    exec env PORT="${PORT:-3001}" bash "$PROJECT_DIR/scripts/dev.sh" "$@"
    ;;
  setup)
    print_header
    exec bash "$PROJECT_DIR/scripts/setup.sh" "$@"
    ;;
  reset)
    print_header
    exec bash "$PROJECT_DIR/scripts/db-reset.sh" "$@"
    ;;
  gen-key)
    # Log in and print the resulting API key for use as PLANSYNC_API_KEY.
    # Usage: ps-admin gen-key [username]
    require_local_node_runtime
    api_url="${PLANSYNC_API_URL:-$(plansync_api_url "${PORT:-3001}")}"
    _GK_USER="${1:-${PLANSYNC_USER:-${USER}}}"
    if [ -t 0 ]; then
      read -r -p "Password for $_GK_USER: " -s _GK_PASS
      echo
    else
      read -r _GK_PASS
    fi
    # Pass credentials via env vars (avoids shell injection in the node script)
    _GK_KEY=$(env _GK_API_URL="$api_url" _GK_USER="$_GK_USER" _GK_PASS="$_GK_PASS" "$LOCAL_NODE_BIN" -e '
const proto = new URL(process.env._GK_API_URL).protocol === "https:" ? "https" : "http";
const lib = require(proto);
const url = new URL(process.env._GK_API_URL + "/api/auth/login");
const body = JSON.stringify({ userName: process.env._GK_USER, password: process.env._GK_PASS });
const req = lib.request({ hostname: url.hostname, port: url.port, path: url.pathname, method: "POST",
  headers: { "Content-Type": "application/json", "Content-Length": Buffer.byteLength(body) } }, res => {
  let d = ""; res.on("data", c => d += c);
  res.on("end", () => {
    try { const j = JSON.parse(d); if (j.key) { process.stdout.write(j.key); } else { process.stderr.write(j.error || d); process.exit(1); } }
    catch { process.stderr.write(d); process.exit(1); }
  });
});
req.on("error", e => { process.stderr.write(e.message); process.exit(1); });
req.write(body); req.end();
' 2>&1) || { echo "Login failed: $_GK_KEY" >&2; exit 1; }
    echo ""
    echo "API Key: $_GK_KEY"
    echo ""
    echo "Add to your shell config:"
    echo "  export PLANSYNC_API_KEY=$_GK_KEY    # bash/zsh"
    echo "  setenv PLANSYNC_API_KEY $_GK_KEY    # tcsh"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "Unknown command: $command" >&2
    echo >&2
    usage >&2
    exit 1
    ;;
esac

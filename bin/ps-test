#!/usr/bin/env bash
# ps-test — PlanSync multi-user end-to-end test suite
#
# Simulates multiple real users interacting with PlanSync to verify:
#   T1: Credential isolation (settings.local.json fix)
#   T2: API permission isolation (member/non-member/owner)
#   T3: Task assignment attribution
#   T4: Plan review workflow
#   T5: Drift alert visibility (including unassigned tasks)
#
# Usage:
#   ./bin/ps-test             # Run all tests, clean up after
#   ./bin/ps-test --keep      # Keep test data for manual inspection
#   ./bin/ps-test --only T2   # Run a single scenario
#
# Requirements:
#   - PlanSync API running (./bin/ps-admin start)
#   - python3 available

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
API="${PLANSYNC_API_URL:-http://localhost:3001}"
KEEP=false
ONLY=""

PASS=0
FAIL=0
SKIP=0
CLEANUP_PROJECT_IDS=()
TMP_BASE="/tmp/ps-test-$$"

# ── Parse args ────────────────────────────────────────────────────────────────

for arg in "$@"; do
  case "$arg" in
    --keep) KEEP=true ;;
    --only) shift; ONLY="${1:-}" ;;
    --only=*) ONLY="${arg#--only=}" ;;
  esac
done

# ── Color output ──────────────────────────────────────────────────────────────

C_GREEN='\033[0;32m'
C_RED='\033[0;31m'
C_YELLOW='\033[0;33m'
C_DIM='\033[2m'
C_RESET='\033[0m'

pass() { PASS=$((PASS+1)); printf "    ${C_GREEN}✓${C_RESET} %s\n" "$1"; }
fail() { FAIL=$((FAIL+1)); printf "    ${C_RED}✗${C_RESET} %s\n" "$1"; }
skip() { SKIP=$((SKIP+1)); printf "    ${C_DIM}○${C_RESET} %s\n" "$1 (skipped)"; }
section() { printf "\n  ${C_YELLOW}%s${C_RESET}\n" "$1"; }

# ── HTTP helpers ──────────────────────────────────────────────────────────────

# api_as <user> <password> <method> <path> [body]
# Returns: JSON body on first line, HTTP status code on last line
api_as() {
  local user="$1" pw="$2" method="$3" path="$4" body="${5:-}"
  local args=(-s -w '\n%{http_code}' -X "$method" "$API$path"
    -H "Authorization: Bearer $pw"
    -H "X-User-Name: $user"
    -H 'Content-Type: application/json')
  [ -n "$body" ] && args+=(-d "$body")
  curl "${args[@]}" 2>/dev/null
}

# Extract HTTP status from last line of api_as output
http_status() { printf '%s' "$1" | tail -1; }

# Extract a field from JSON (first line of api_as output)
json_get() {
  printf '%s' "$1" | head -1 \
    | python3 -c "import sys,json
d=json.load(sys.stdin)
parts='$2'.split('.')
for p in parts:
    if p.startswith('['):
        d=d[int(p[1:-1])]
    else:
        d=d.get(p,'') if isinstance(d,dict) else ''
print(d)" 2>/dev/null || printf ''
}

# ── Test users ────────────────────────────────────────────────────────────────

# Use PID in username to avoid conflicts across concurrent runs
OWNER="ps-test-owner-$$"
USERB="ps-test-userb-$$"
USERC="ps-test-userc-$$"

# Use a fixed password pattern that is distinct from real user passwords
PW_SUFFIX="Ps!Test$(printf '%04x' $((RANDOM % 65536)))"
OWNER_PW="ownerPw-${PW_SUFFIX}"
USERB_PW="userbPw-${PW_SUFFIX}"
USERC_PW="usercPw-${PW_SUFFIX}"

# ── Setup: register test users ────────────────────────────────────────────────

setup_users() {
  printf "  Registering test users..."
  local failed=0
  for pair in "$OWNER:$OWNER_PW" "$USERB:$USERB_PW" "$USERC:$USERC_PW"; do
    local u="${pair%%:*}" pw="${pair##*:}"
    local r; r=$(api_as "$u" "$pw" POST /api/auth/register \
      "{\"userName\":\"$u\",\"password\":\"$pw\"}" 2>/dev/null)
    local code; code=$(http_status "$r")
    # 200 = registered, 409/400 = already exists (try login to verify)
    if [ "$code" != "200" ]; then
      local lr; lr=$(api_as "$u" "$pw" POST /api/auth/login \
        "{\"userName\":\"$u\",\"password\":\"$pw\"}" 2>/dev/null)
      local lcode; lcode=$(http_status "$lr")
      if [ "$lcode" != "200" ]; then
        printf "\n  Error: cannot register or login as %s (HTTP %s)\n" "$u" "$lcode"
        failed=$((failed+1))
      fi
    fi
  done
  if [ "$failed" -gt 0 ]; then
    printf "\n  FATAL: user setup failed. Is the API running at %s?\n" "$API"
    exit 1
  fi
  printf " done\n"
}

# ── Cleanup ───────────────────────────────────────────────────────────────────

cleanup() {
  if $KEEP; then
    printf "\n  ${C_DIM}--keep specified: leaving test data. Owner: %s, Projects: %s${C_RESET}\n" \
      "$OWNER" "${CLEANUP_PROJECT_IDS[*]:-none}"
    return
  fi
  for pid in "${CLEANUP_PROJECT_IDS[@]:-}"; do
    api_as "$OWNER" "$OWNER_PW" DELETE "/api/projects/$pid" >/dev/null 2>&1 || true
  done
  rm -rf "$TMP_BASE"
}

trap cleanup EXIT

# ── T1: Credential isolation ──────────────────────────────────────────────────

run_T1() {
  section "T1: Credential isolation"

  # T1a: settings.local.json must not contain user credentials
  local sf="$PROJECT_DIR/.claude/settings.local.json"
  if [ ! -f "$sf" ]; then
    pass "settings.local.json does not exist (no credentials to leak)"
  elif python3 -c "
import json,sys
d=json.load(open('$sf'))
env=d.get('mcpServers',{}).get('plansync',{}).get('env',{})
if 'PLANSYNC_API_KEY' in env or 'PLANSYNC_USER' in env:
    sys.exit(1)
" 2>/dev/null; then
    pass "settings.local.json has no hardcoded credentials"
  else
    fail "settings.local.json contains PLANSYNC_API_KEY or PLANSYNC_USER (credential leak)"
  fi

  # T1b: bin/start-mcp reads credentials from the correct \$HOME
  local fake_home="$TMP_BASE/fake-home"
  mkdir -p "$fake_home/.config/plansync"
  printf 'PLANSYNC_API_KEY=fake-key-for-test\nPLANSYNC_USER=ps-test-fake-identity\n' \
    > "$fake_home/.config/plansync/env"

  # Source start-mcp up to the env-loading step and capture PLANSYNC_USER
  local resolved
  resolved=$(HOME="$fake_home" USER="ps-test-fake-identity" bash -c '
    SCRIPT_DIR="'"$SCRIPT_DIR"'"
    PROJECT_DIR="'"$PROJECT_DIR"'"
    _load_env() {
      [ -f "$1" ] || return 0
      while IFS= read -r _line; do
        [[ "$_line" =~ ^[[:space:]]*($|#) ]] && continue
        local _key="${_line%%=*}"; _key="${_key// /}"
        [ -n "${!_key+set}" ] || export "$_line"
      done < "$1"
    }
    _load_env "$HOME/.config/plansync/env"
    _load_env "$PROJECT_DIR/.env"
    export PLANSYNC_USER="${PLANSYNC_USER:-$USER}"
    printf "%s" "$PLANSYNC_USER"
  ' 2>/dev/null)

  if [ "$resolved" = "ps-test-fake-identity" ]; then
    pass "start-mcp reads PLANSYNC_USER from correct \$HOME"
  else
    fail "start-mcp resolved PLANSYNC_USER='$resolved', expected 'ps-test-fake-identity'"
  fi
}

# ── T2: API permission isolation ─────────────────────────────────────────────

run_T2() {
  section "T2: API permission isolation"

  # Create project as owner
  local r; r=$(api_as "$OWNER" "$OWNER_PW" POST /api/projects \
    "{\"name\":\"ps-test-project-$$\"}")
  local code; code=$(http_status "$r")
  if [ "$code" != "200" ] && [ "$code" != "201" ]; then
    fail "owner cannot create project (HTTP $code)"
    return
  fi
  local proj_id; proj_id=$(json_get "$r" "data.id")
  CLEANUP_PROJECT_IDS+=("$proj_id")

  # Invite USERB as developer, leave USERC out
  r=$(api_as "$OWNER" "$OWNER_PW" POST "/api/projects/$proj_id/members" \
    "{\"name\":\"$USERB\",\"role\":\"developer\",\"type\":\"human\"}")
  code=$(http_status "$r")
  [ "$code" = "200" ] || [ "$code" = "201" ] \
    && pass "owner can add member" \
    || fail "owner failed to add member (HTTP $code)"

  # USERB (member) can read project
  r=$(api_as "$USERB" "$USERB_PW" GET "/api/projects/$proj_id")
  code=$(http_status "$r")
  [ "$code" = "200" ] \
    && pass "member can read project" \
    || fail "member cannot read project (HTTP $code)"

  # USERC (non-member) is forbidden
  r=$(api_as "$USERC" "$USERC_PW" GET "/api/projects/$proj_id")
  code=$(http_status "$r")
  [ "$code" = "403" ] || [ "$code" = "404" ] \
    && pass "non-member is forbidden" \
    || fail "non-member got HTTP $code (expected 403)"

  # USERB (developer) cannot delete project
  r=$(api_as "$USERB" "$USERB_PW" DELETE "/api/projects/$proj_id")
  code=$(http_status "$r")
  [ "$code" = "403" ] \
    && pass "developer cannot delete project" \
    || fail "developer delete got HTTP $code (expected 403)"
}

# ── T3: Task assignment attribution ──────────────────────────────────────────

run_T3() {
  section "T3: Task assignment attribution"

  # Create project and add member
  local r; r=$(api_as "$OWNER" "$OWNER_PW" POST /api/projects \
    "{\"name\":\"ps-test-task-proj-$$\"}")
  local proj_id; proj_id=$(json_get "$r" "data.id")
  CLEANUP_PROJECT_IDS+=("$proj_id")
  api_as "$OWNER" "$OWNER_PW" POST "/api/projects/$proj_id/members" \
    "{\"name\":\"$USERB\",\"role\":\"developer\",\"type\":\"human\"}" >/dev/null

  # Create and activate a plan (required before creating tasks)
  r=$(api_as "$OWNER" "$OWNER_PW" POST "/api/projects/$proj_id/plans" \
    "{\"title\":\"T3 plan\",\"goal\":\"Test task attribution\",\"scope\":\"All\"}")
  local plan_id; plan_id=$(json_get "$r" "data.id")
  api_as "$OWNER" "$OWNER_PW" POST "/api/projects/$proj_id/plans/$plan_id/activate" \
    '{}' >/dev/null

  # Create task assigned to USERB
  r=$(api_as "$OWNER" "$OWNER_PW" POST "/api/projects/$proj_id/tasks" \
    "{\"title\":\"Test task for attribution\",\"type\":\"code\",\"assignee\":\"$USERB\",\"assigneeType\":\"human\"}")
  local code; code=$(http_status "$r")
  [ "$code" = "200" ] || [ "$code" = "201" ] \
    && pass "owner can create assigned task" \
    || { fail "owner failed to create task (HTTP $code)"; return; }
  local task_id; task_id=$(json_get "$r" "data.id")

  # USERB starts execution
  r=$(api_as "$USERB" "$USERB_PW" POST "/api/projects/$proj_id/tasks/$task_id/runs" \
    "{\"executorType\":\"human\",\"executorName\":\"$USERB\"}")
  code=$(http_status "$r")
  [ "$code" = "200" ] || [ "$code" = "201" ] \
    && pass "member can start execution run" \
    || fail "member failed to start run (HTTP $code)"

  # Verify task assignee recorded correctly
  r=$(api_as "$OWNER" "$OWNER_PW" GET "/api/projects/$proj_id/tasks/$task_id")
  local assignee; assignee=$(json_get "$r" "data.assignee")
  local status; status=$(json_get "$r" "data.status")
  [ "$assignee" = "$USERB" ] \
    && pass "task.assignee = userb (correct attribution)" \
    || fail "task.assignee = '$assignee' (expected '$USERB')"
  [ "$status" = "in_progress" ] \
    && pass "task.status = in_progress after execution start" \
    || fail "task.status = '$status' (expected 'in_progress')"
}

# ── T4: Plan review workflow ──────────────────────────────────────────────────

run_T4() {
  section "T4: Plan review workflow"

  # Create project and add USERB as member
  local r; r=$(api_as "$OWNER" "$OWNER_PW" POST /api/projects \
    "{\"name\":\"ps-test-plan-proj-$$\"}")
  local proj_id; proj_id=$(json_get "$r" "data.id")
  CLEANUP_PROJECT_IDS+=("$proj_id")
  api_as "$OWNER" "$OWNER_PW" POST "/api/projects/$proj_id/members" \
    "{\"name\":\"$USERB\",\"role\":\"developer\",\"type\":\"human\"}" >/dev/null

  # Create and propose a plan with USERB as reviewer
  r=$(api_as "$OWNER" "$OWNER_PW" POST "/api/projects/$proj_id/plans" \
    "{\"title\":\"Test plan\",\"goal\":\"Verify plan review workflow\",\"scope\":\"E2E test\"}")
  local code; code=$(http_status "$r")
  [ "$code" = "200" ] || [ "$code" = "201" ] \
    && pass "owner can create plan" \
    || { fail "owner failed to create plan (HTTP $code)"; return; }
  local plan_id; plan_id=$(json_get "$r" "data.id")

  # Propose with USERB as required reviewer
  r=$(api_as "$OWNER" "$OWNER_PW" POST "/api/projects/$proj_id/plans/$plan_id/propose" \
    "{\"reviewers\":[\"$USERB\"]}")
  code=$(http_status "$r")
  [ "$code" = "200" ] || [ "$code" = "201" ] \
    && pass "owner can propose plan with reviewer" \
    || fail "propose failed (HTTP $code)"

  # Get USERB's reviewId (created by propose)
  r=$(api_as "$OWNER" "$OWNER_PW" GET "/api/projects/$proj_id/plans/$plan_id/reviews")
  local review_id; review_id=$(json_get "$r" "data.[0].id")
  local reviewer; reviewer=$(json_get "$r" "data.[0].reviewerName")
  [ "$reviewer" = "$USERB" ] \
    && pass "review record created for correct reviewer" \
    || fail "review.reviewerName = '$reviewer' (expected '$USERB')"

  # USERB approves via the correct endpoint: POST /reviews/:reviewId?action=approve
  r=$(api_as "$USERB" "$USERB_PW" POST \
    "/api/projects/$proj_id/plans/$plan_id/reviews/$review_id?action=approve" \
    "{\"comment\":\"Looks good\"}")
  code=$(http_status "$r")
  [ "$code" = "200" ] || [ "$code" = "201" ] \
    && pass "reviewer can approve plan" \
    || fail "reviewer approve failed (HTTP $code)"

  # Verify review status updated
  r=$(api_as "$OWNER" "$OWNER_PW" GET "/api/projects/$proj_id/plans/$plan_id/reviews")
  local review_status; review_status=$(json_get "$r" "data.[0].status")
  [ "$review_status" = "approved" ] \
    && pass "review.status = approved" \
    || fail "review.status = '$review_status' (expected 'approved')"
}

# ── T5: Drift alert visibility (including unassigned tasks) ───────────────────

run_T5() {
  section "T5: Drift alert visibility"

  # Create project, plan v1
  local r; r=$(api_as "$OWNER" "$OWNER_PW" POST /api/projects \
    "{\"name\":\"ps-test-drift-proj-$$\"}")
  local proj_id; proj_id=$(json_get "$r" "data.id")
  CLEANUP_PROJECT_IDS+=("$proj_id")
  api_as "$OWNER" "$OWNER_PW" POST "/api/projects/$proj_id/members" \
    "{\"name\":\"$USERB\",\"role\":\"developer\",\"type\":\"human\"}" >/dev/null

  # Create plan, activate it
  r=$(api_as "$OWNER" "$OWNER_PW" POST "/api/projects/$proj_id/plans" \
    "{\"title\":\"v1\",\"goal\":\"Initial plan\",\"scope\":\"All\"}")
  local plan_id; plan_id=$(json_get "$r" "data.id")
  api_as "$OWNER" "$OWNER_PW" POST "/api/projects/$proj_id/plans/$plan_id/activate" \
    '{}' >/dev/null 2>&1 || true

  # Create an unassigned task (assignee=null) bound to this plan
  r=$(api_as "$OWNER" "$OWNER_PW" POST "/api/projects/$proj_id/tasks" \
    "{\"title\":\"Unassigned task\",\"type\":\"code\"}")
  local task_id; task_id=$(json_get "$r" "data.id")

  # Create plan v2 (triggers drift for tasks bound to v1)
  r=$(api_as "$OWNER" "$OWNER_PW" POST "/api/projects/$proj_id/plans" \
    "{\"title\":\"v2\",\"goal\":\"Updated plan\",\"scope\":\"All\"}")
  local plan_v2_id; plan_v2_id=$(json_get "$r" "data.id")
  api_as "$OWNER" "$OWNER_PW" POST "/api/projects/$proj_id/plans/$plan_v2_id/activate" \
    '{}' >/dev/null 2>&1 || true

  # Wait briefly for drift to be computed
  sleep 1

  # Verify: USERB (member) can see drift alert for unassigned task via my-work
  r=$(api_as "$USERB" "$USERB_PW" GET "/api/my-work?projectId=$proj_id")
  local drift_count
  drift_count=$(printf '%s' "$r" | head -1 \
    | python3 -c "import sys,json; d=json.load(sys.stdin); print(len(d.get('drifts',[])))" 2>/dev/null || printf '0')

  if [ "$drift_count" -gt 0 ]; then
    pass "member sees drift alert for unassigned task in plansync_my_work"
  else
    # Drift may not have been created yet — check directly
    local drift_r; drift_r=$(api_as "$OWNER" "$OWNER_PW" GET \
      "/api/projects/$proj_id/drifts?status=open")
    local total
    total=$(printf '%s' "$drift_r" | head -1 \
      | python3 -c "import sys,json; d=json.load(sys.stdin); print(len(d.get('data',[])))" 2>/dev/null || printf '0')
    if [ "$total" -gt 0 ]; then
      fail "drift alerts exist ($total) but do NOT appear in member's my-work (Bug A not fixed?)"
    else
      skip "no drift alerts created (plan change may not trigger drift without task binding)"
    fi
  fi
}

# ── Main ──────────────────────────────────────────────────────────────────────

printf "\n${C_YELLOW}PlanSync Multi-User Test Suite${C_RESET}\n"
printf "  API: %s\n" "$API"
printf "  PID: %s\n\n" "$$"

# Verify API is reachable
if ! curl -s --connect-timeout 3 "$API/api/health" >/dev/null 2>&1; then
  printf "${C_RED}Error:${C_RESET} PlanSync API not reachable at %s\n" "$API"
  printf "  Start it first: ./bin/ps-admin start\n\n"
  exit 1
fi

setup_users

if [ -n "$ONLY" ]; then
  "run_$ONLY"
else
  run_T1
  run_T2
  run_T3
  run_T4
  run_T5
fi

printf "\n──────────────────────────────────────\n"
printf "  ${C_GREEN}%d passed${C_RESET}" "$PASS"
printf "  ${C_RED}%d failed${C_RESET}" "$FAIL"
[ "$SKIP" -gt 0 ] && printf "  ${C_DIM}%d skipped${C_RESET}" "$SKIP"
printf "\n──────────────────────────────────────\n\n"

[ "$FAIL" -eq 0 ]
